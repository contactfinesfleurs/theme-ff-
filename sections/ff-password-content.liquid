<div class="ff-password-layout">
  <div class="ff-password-card">
    <h1 class="ff-password-brand">FINES FLEURS</h1>
    <p class="ff-password-subtitle">{{ section.settings.subtitle }}</p>

    {%- form 'customer', class: 'ff-password-form' -%}
      <input type="hidden" name="customer[tags]" value="newsletter,password-page">
      <input
        class="ff-input"
        type="email"
        name="contact[email]"
        placeholder="Email"
        required>
      <button type="submit" class="ff-password-button">{{ section.settings.newsletter_button }}</button>
    {%- endform -%}

    <div class="ff-password-form">
      {%- form 'storefront_password' -%}
        <input
          class="ff-input"
          type="password"
          name="password"
          placeholder="Password"
          required>
        <button type="submit" class="ff-password-button">{{ section.settings.password_button }}</button>
      {%- endform -%}
    </div>

    <a href="/admin" class="ff-password-owner">Store owner access</a>
  </div>
</div>

{% schema %}
{
  "name": "FF Password Content",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Site under maintenance or private drop access"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Newsletter button",
      "default": "Notify me"
    },
    {
      "type": "text",
      "id": "password_button",
      "label": "Password button",
      "default": "Enter"
    }
  ],
  "presets": [
    {
      "name": "FF Password Content"
    }
  ]
}
{% endschema %}
