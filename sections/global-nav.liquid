{%- comment -%}
  Global Navigation Bar — rendered on all pages except password.
  Shows: Logo (left) | Nav links with active underline (center) | Cart icon (right)
{%- endcomment -%}

{%- liquid
  assign is_home = false
  assign is_shop = false
  assign is_about = false
  assign is_contact = false

  if request.page_type == 'index'
    assign is_home = true
  elsif request.page_type == 'collection' or request.page_type == 'product' or template.name == 'list-collections'
    assign is_shop = true
  elsif page.handle == 'about' or template.suffix == 'about'
    assign is_about = true
  elsif page.handle == 'contact' or template.suffix == 'contact'
    assign is_contact = true
  endif
-%}

<nav class="w-full bg-white relative z-50">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 py-5 flex items-center justify-between">

    {%- comment -%} Logo — far left {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="flex-shrink-0">
      {% if settings.enter_screen_logo %}
        <img
          src="{{ settings.enter_screen_logo | image_url: width: 300 }}"
          alt="{{ shop.name | escape }}"
          class="h-6 sm:h-7 w-auto"
          loading="eager"
          decoding="sync"
          fetchpriority="high">
      {% else %}
        <span class="text-base sm:text-lg font-bold tracking-[0.15em] uppercase">FINES FLEURS</span>
      {% endif %}
    </a>

    {%- comment -%} Nav links — center {%- endcomment -%}
    <div class="flex items-center gap-4 sm:gap-6 md:gap-10 text-xs sm:text-sm tracking-wide lowercase font-medium">
      <a href="{{ routes.root_url }}"
         class="pb-1 transition-colors hover:text-black {% if is_home %}border-b border-black text-black{% else %}text-gray-600{% endif %}">
        home
      </a>
      <a href="{% if collections['all'] %}{{ collections['all'].url }}{% else %}/collections/all{% endif %}"
         class="pb-1 transition-colors hover:text-black {% if is_shop %}border-b border-black text-black{% else %}text-gray-600{% endif %}">
        shop
      </a>
      <a href="/pages/about"
         class="pb-1 transition-colors hover:text-black {% if is_about %}border-b border-black text-black{% else %}text-gray-600{% endif %}">
        us
      </a>
      <a href="/pages/contact"
         class="pb-1 transition-colors hover:text-black {% if is_contact %}border-b border-black text-black{% else %}text-gray-600{% endif %}">
        contact
      </a>
    </div>

    {%- comment -%} Cart icon — far right {%- endcomment -%}
    <a href="{{ routes.cart_url }}" class="flex-shrink-0 relative group cart-icon-trigger" aria-label="Cart">
      <div class="w-6 h-6 sm:w-7 sm:h-7 border border-black rounded-sm flex items-center justify-center transition-colors group-hover:bg-black group-hover:text-white">
        {% if cart.item_count > 0 %}
          <span class="text-[10px] sm:text-xs font-medium">{{ cart.item_count }}</span>
        {% endif %}
      </div>
    </a>

  </div>
</nav>

<script>
  {%- comment -%} Make cart icon open the cart drawer if it exists {%- endcomment -%}
  document.addEventListener('DOMContentLoaded', function() {
    var cartTrigger = document.querySelector('.cart-icon-trigger');
    var cartDrawer = document.querySelector('.cart-drawer') || document.querySelector('[data-cart-drawer]');
    if (cartTrigger && cartDrawer) {
      cartTrigger.addEventListener('click', function(e) {
        e.preventDefault();
        {%- comment -%} Try to trigger the existing cart drawer open mechanism {%- endcomment -%}
        var menuBtn = document.querySelector('.menu-btn');
        if (document.querySelector('.pushy-open')) {
          {%- comment -%} If pushy menu is open, close it first {%- endcomment -%}
        }
        {%- comment -%} Trigger cart drawer via existing cart-count click {%- endcomment -%}
        var existingCartBtn = document.querySelector('.cart-text');
        if (existingCartBtn) {
          existingCartBtn.click();
        } else {
          window.location.href = '{{ routes.cart_url }}';
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Global Navigation",
  "tag": "header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "paragraph",
      "content": "Navigation links are fixed: home, shop, us, contact. The active page is indicated with an underline."
    }
  ],
  "presets": [
    {
      "name": "Global Navigation"
    }
  ]
}
{% endschema %}
