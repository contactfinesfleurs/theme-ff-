{%- comment -%}
  Contact Form — Clean Tailwind layout
{%- endcomment -%}

<div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 sm:py-24">
  <div class="border border-gray-200 px-6 sm:px-12 py-10 sm:py-16">

    <h2 class="text-center text-sm uppercase tracking-[0.15em] text-gray-500 mb-10">
      contact us
    </h2>

    {%- form "contact", class: "space-y-4" -%}

      {%- comment -%} First Name / Last Name row {%- endcomment -%}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <input
          type="text"
          name="contact[first_name]"
          placeholder="{{ 'general.contact.first_name' | t }}"
          maxlength="256"
          class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
        <input
          type="text"
          name="contact[last_name]"
          placeholder="{{ 'general.contact.last_name' | t }}"
          maxlength="256"
          required=""
          class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
      </div>

      {%- comment -%} Email / Order Number row {%- endcomment -%}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ 'general.contact.email' | t }}"
          maxlength="256"
          required=""
          class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
        <input
          type="text"
          name="contact[order_number]"
          placeholder="{{ 'general.contact.order_number' | t }}"
          maxlength="256"
          class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
      </div>

      {%- comment -%} Subject {%- endcomment -%}
      <input
        type="text"
        name="contact[subject]"
        placeholder="{{ 'general.contact.subject' | t }}"
        maxlength="256"
        class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">

      {%- comment -%} Message {%- endcomment -%}
      <textarea
        name="contact[body]"
        placeholder="{{ 'general.contact.message' | t }}"
        maxlength="5000"
        required=""
        rows="6"
        class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors resize-y"></textarea>

      {%- comment -%} Buttons {%- endcomment -%}
      <div class="flex items-center justify-between pt-2">
        <a href="{{ routes.root_url }}"
           class="bg-black text-white text-xs uppercase tracking-widest px-6 py-3 hover:bg-gray-800 transition-colors no-underline">
          Back Home
        </a>
        <input
          type="submit"
          value="{{ 'general.contact.submit' | t }}"
          data-wait="Please wait..."
          class="bg-black text-white text-xs uppercase tracking-widest px-8 py-3 hover:bg-gray-800 transition-colors cursor-pointer border-none">
      </div>

      {%- assign form_success = form.posted_successfully? -%}
      {%- assign form_errors = form.errors -%}
      {%- render "form-general-script", form_success: form_success, form_errors: form_errors -%}
    {%- endform -%}

    {%- comment -%} Success message {%- endcomment -%}
    <div class="hidden mt-6 text-center {% if form_success %}!block{% endif %}">
      <p class="text-sm text-green-600 mb-4">Thank you! Your message has been sent.</p>
      <a href="{{ routes.root_url }}" class="text-sm text-black underline hover:text-gray-600">Return Home</a>
    </div>

    {%- comment -%} Error message {%- endcomment -%}
    {%- unless form_success -%}
      <div class="hidden mt-4 {% if form_errors %}!block{% endif %}">
        <div class="text-sm text-red-500">
          {%- render "form-errors", form_errors: form_errors -%}
        </div>
      </div>
    {%- endunless -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "tag": "div",
  "settings": [],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
