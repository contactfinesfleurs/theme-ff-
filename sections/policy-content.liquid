{%- comment -%}
  Policy / Legal Page — Clean Tailwind layout for Shopify policy pages
  (refund, privacy, terms of service, shipping)
{%- endcomment -%}

<div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 sm:py-24">
  <div class="border border-gray-200 px-6 sm:px-12 py-10 sm:py-16">

    {%- comment -%} Page title {%- endcomment -%}
    <h1 class="text-center text-sm uppercase tracking-[0.15em] text-gray-500 mb-10">
      {{ policy.title | default: page.title }}
    </h1>

    {%- comment -%} Content {%- endcomment -%}
    <div class="text-sm sm:text-base text-gray-700 leading-relaxed prose prose-sm max-w-none
                prose-headings:text-black prose-headings:text-base prose-headings:font-medium prose-headings:mt-8 prose-headings:mb-3
                prose-p:mb-4 prose-ul:list-disc prose-ul:pl-5 prose-ol:list-decimal prose-ol:pl-5
                prose-a:text-black prose-a:underline hover:prose-a:text-gray-600">
      {{ policy.body | default: page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Policy Content",
  "settings": [],
  "presets": [
    {
      "name": "Policy Content"
    }
  ]
}
{% endschema %}
