<div class="ff-shell">
  {% render 'ff-site-nav', variant: 'page' %}

  <main class="ff-contact-wrap">
    <h1 class="ff-contact-title">{{ page.title | default: 'contact' }}</h1>

    {%- form 'contact', class: 'ff-contact-form' -%}
      <input
        class="ff-input"
        type="text"
        name="contact[name]"
        placeholder="Full name"
        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        autocomplete="name">

      <input
        class="ff-input"
        type="email"
        name="contact[email]"
        placeholder="Email"
        value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
        required
        autocomplete="email">

      <input
        class="ff-input"
        type="tel"
        name="contact[phone]"
        placeholder="Phone"
        value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
        autocomplete="tel">

      <textarea
        class="ff-textarea"
        name="contact[body]"
        placeholder="Message"
        required>{{ form.body }}</textarea>

      <button type="submit" class="ff-contact-submit">Send</button>

      {% if form.posted_successfully? %}
        <p class="ff-form-note ff-form-note--success">Merci, votre message a bien ete envoye.</p>
      {% endif %}

      {% if form.errors %}
        <div class="ff-form-note ff-form-note--error">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
    {%- endform -%}
  </main>
</div>

{% schema %}
{
  "name": "FF Contact Form",
  "settings": [],
  "presets": [
    {
      "name": "FF Contact Form"
    }
  ]
}
{% endschema %}
