{%- comment -%}
  Collection Products Display — Clean Tailwind 3-column grid
  Replaces the old collection page with logo/clock/menu/search header
{%- endcomment -%}

<style>
  img.lazyload:not([src]) { visibility: hidden; }
  .blur-up { filter: blur(5px); transition: filter 400ms; }
  .blur-up.lazyloaded { filter: blur(0); }
  .collection-item { opacity: 0; transform: translateY(10px); transition: opacity 0.4s ease, transform 0.4s ease; }
  .collection-item.fade-in { opacity: 1; transform: translateY(0); }
</style>

<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 py-8 sm:py-12">

  {%- if collection -%}
    {%- if collection.products.size > 0 -%}

      {% paginate collection.products by 24 %}

      <div id="product-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-x-4 sm:gap-x-6 lg:gap-x-8 gap-y-8 sm:gap-y-10 lg:gap-y-14">
        {% for item in collection.products %}
          <div class="collection-item">
            <a href="{{ item.url | within: collection }}" class="group block">
              <div class="relative aspect-[3/4] overflow-hidden bg-gray-50">
                {% if settings.enable_lazy_loading %}
                  <img
                    src="{{ item.featured_media.preview_image | img_url: '50x' }}"
                    data-sizes="auto"
                    data-srcset="
                      {{ item.featured_media.preview_image | img_url: '400x' }} 400w,
                      {{ item.featured_media.preview_image | img_url: '600x' }} 600w,
                      {{ item.featured_media.preview_image | img_url: '800x' }} 800w,
                      {{ item.featured_media.preview_image | img_url: '1024x' }} 1024w"
                    alt="{{ item.featured_media.preview_image.alt | escape }}"
                    class="w-full h-full object-cover lazyload blur-up group-hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy">
                {% else %}
                  <img
                    src="{{ item.featured_media.preview_image | img_url: '800x' }}"
                    alt="{{ item.featured_media.preview_image.alt | escape }}"
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy">
                {% endif %}

                {% if settings.enable_product_hover and item.media[1].preview_image != null and item.media[1].media_type != 'video' and item.media[1].media_type != 'external_video' %}
                  <img
                    {% if settings.enable_lazy_loading %}
                    src="{{ item.media[1].preview_image | img_url: '50x' }}"
                    data-sizes="auto"
                    data-srcset="
                      {{ item.media[1].preview_image | img_url: '400x' }} 400w,
                      {{ item.media[1].preview_image | img_url: '600x' }} 600w,
                      {{ item.media[1].preview_image | img_url: '800x' }} 800w"
                    class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500 lazyload blur-up"
                    {% else %}
                    src="{{ item.media[1].preview_image | img_url: '800x' }}"
                    class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    {% endif %}
                    alt="{{ item.media[1].preview_image.alt | escape }}"
                    loading="lazy">
                {% endif %}

                {%- comment -%} Out of stock label {%- endcomment -%}
                {% if item.available == false and section.settings.show_oos %}
                  <div class="absolute bottom-2 left-2 bg-gray-500 text-white text-[10px] px-2 py-0.5 uppercase tracking-wider">
                    {{ 'collection.sold_out' | t }}
                  </div>
                {% endif %}

                {%- comment -%} On sale label {%- endcomment -%}
                {% if item.available and section.settings.show_on_sale and item.compare_at_price and item.compare_at_price > 0 %}
                  <div class="absolute bottom-2 left-2 bg-black text-white text-[10px] px-2 py-0.5 uppercase tracking-wider">
                    {{ 'collection.on_sale' | t }}
                  </div>
                {% endif %}
              </div>

              {%- comment -%} Product info below image {%- endcomment -%}
              <div class="mt-3 text-center">
                {%- if section.settings.show_title -%}
                  <h3 class="text-xs sm:text-sm font-medium text-black tracking-wide">{{ item.title }}</h3>
                {%- endif -%}

                {%- if section.settings.show_price -%}
                  <p class="mt-1 text-xs sm:text-sm text-gray-600">
                    {% if section.settings.currency_format == "with_currency" %}
                      {{ item.price | money_with_currency }}
                    {% else %}
                      {{ item.price | money }}
                    {% endif %}
                  </p>
                  {% if section.settings.show_compare_price and item.compare_at_price > item.price %}
                    <p class="text-xs text-red-500 line-through">
                      {% if section.settings.currency_format == "with_currency" %}
                        {{ item.compare_at_price | money_with_currency }}
                      {% else %}
                        {{ item.compare_at_price | money }}
                      {% endif %}
                    </p>
                  {% endif %}
                {%- endif -%}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {% if section.settings.pagination_type == 'infinite_scroll' and paginate.next %}
        <div id="loading-spinner" class="hidden text-center py-8">
          <div class="w-8 h-8 border-2 border-gray-200 border-t-gray-800 rounded-full animate-spin mx-auto"></div>
        </div>
        <div id="pagination-url"
             data-current-page="{{ paginate.current_page }}"
             data-collection-handle="{{ collection.handle }}">
        </div>
      {% elsif section.settings.pagination_type == 'pagination' %}
        <div class="flex justify-center items-center gap-2 mt-12 text-sm">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="px-3 py-2 text-black hover:underline">&larr;</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="px-3 py-2 text-black hover:underline">{{ part.title }}</a>
            {% else %}
              <span class="px-3 py-2 bg-black text-white rounded">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="px-3 py-2 text-black hover:underline">&rarr;</a>
          {% endif %}
        </div>
      {% endif %}

      {% endpaginate %}

    {%- else -%}
      <div class="text-center py-20 text-gray-400 text-sm">
        No products in this collection yet.
      </div>
    {%- endif -%}

  {%- else -%}
    {%- comment -%} Fallback: show all products if no collection context {%- endcomment -%}
    {% paginate collections.all.products by 24 %}
      <div id="product-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-x-4 sm:gap-x-6 lg:gap-x-8 gap-y-8 sm:gap-y-10 lg:gap-y-14">
        {% for item in collections.all.products %}
          <div class="collection-item">
            <a href="{{ item.url }}" class="group block">
              <div class="relative aspect-[3/4] overflow-hidden bg-gray-50">
                <img
                  src="{{ item.featured_image | img_url: '800x' }}"
                  alt="{{ item.featured_image.alt | escape }}"
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                  loading="lazy">
              </div>
              <div class="mt-3 text-center">
                <h3 class="text-xs sm:text-sm font-medium text-black tracking-wide">{{ item.title }}</h3>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% endpaginate %}
  {%- endif -%}

</div>

<script src="{{ 'lazyloadz.js' | asset_url }}" type="text/javascript"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  /* Product fade-in animation */
  var productObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry, index) {
      if (entry.isIntersecting) {
        setTimeout(function() { entry.target.classList.add('fade-in'); }, index * 50);
        productObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  function observeProducts() {
    document.querySelectorAll('.collection-item').forEach(function(p) { productObserver.observe(p); });
  }
  observeProducts();

  /* Infinite scroll */
  var paginationType = '{{ section.settings.pagination_type }}';
  if (paginationType === 'infinite_scroll') {
    var loading = false, reachedEnd = false;
    var grid = document.getElementById('product-grid');
    var spinner = document.getElementById('loading-spinner');
    var paginationEl = document.getElementById('pagination-url');
    if (!paginationEl) return;

    function loadMore() {
      if (loading || reachedEnd || !paginationEl) return;
      var page = parseInt(paginationEl.dataset.currentPage) + 1;
      var handle = paginationEl.dataset.collectionHandle;
      var params = new URLSearchParams(window.location.search);
      params.set('page', page);
      loading = true;
      if (spinner) spinner.classList.remove('hidden');

      fetch('/collections/' + handle + '?' + params.toString())
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var newItems = doc.querySelectorAll('.collection-item');
          if (newItems.length > 0) {
            newItems.forEach(function(item) {
              var clone = item.cloneNode(true);
              grid.appendChild(clone);
              productObserver.observe(clone);
            });
            paginationEl.dataset.currentPage = page;
            if (!doc.querySelector('#pagination-url')) { reachedEnd = true; if(spinner) spinner.remove(); }
          } else {
            reachedEnd = true; if(spinner) spinner.remove();
          }
        })
        .catch(function(e) { console.error('Error loading products:', e); })
        .finally(function() { loading = false; if(spinner) spinner.classList.add('hidden'); });
    }

    window.addEventListener('scroll', function() {
      if (loading || reachedEnd) return;
      var scrollPos = window.scrollY + window.innerHeight;
      var totalHeight = document.body.scrollHeight;
      if (totalHeight - scrollPos < 800) loadMore();
    }, { passive: true });
  }
});
</script>

{% schema %}
{
  "name": "Collection Products",
  "blocks": [
    {
      "type": "sort_option",
      "name": "Sort Option",
      "settings": [
        { "type": "text", "id": "title", "label": "Option Title", "default": "Featured" },
        {
          "type": "select", "id": "sort_by", "label": "Sort by",
          "options": [
            { "value": "manual", "label": "Featured" },
            { "value": "best-selling", "label": "Best Selling" },
            { "value": "title-ascending", "label": "A-Z" },
            { "value": "title-descending", "label": "Z-A" },
            { "value": "price-ascending", "label": "Price: Low to High" },
            { "value": "price-descending", "label": "Price: High to Low" },
            { "value": "created-descending", "label": "Newest First" },
            { "value": "created-ascending", "label": "Oldest First" }
          ],
          "default": "manual"
        }
      ]
    }
  ],
  "presets": [{ "name": "Collection Products" }],
  "disabled_on": {
    "templates": ["404","article","blog","cart","product","list-collections","customers/account",
      "customers/activate_account","customers/addresses","customers/login","customers/order",
      "customers/register","customers/reset_password","gift_card","index","page","password","search"]
  },
  "settings": [
    { "type": "header", "content": "Product Display" },
    { "type": "checkbox", "id": "show_title", "label": "Show Product Titles", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show Product Prices", "default": true },
    { "type": "checkbox", "id": "show_compare_price", "label": "Show Compare Prices", "default": false },
    {
      "type": "radio", "id": "currency_format", "label": "Currency Format",
      "options": [
        { "value": "with_currency", "label": "With Currency" },
        { "value": "without_currency", "label": "Without Currency" }
      ],
      "default": "without_currency"
    },
    { "type": "header", "content": "Labels" },
    { "type": "checkbox", "id": "show_on_sale", "label": "Show On Sale Labels", "default": false },
    { "type": "checkbox", "id": "show_oos", "label": "Show Out Of Stock Labels", "default": true },
    { "type": "header", "content": "Pagination" },
    {
      "type": "select", "id": "pagination_type", "label": "Pagination Type",
      "options": [
        { "value": "infinite_scroll", "label": "Infinite Scroll" },
        { "value": "pagination", "label": "Page Numbers" }
      ],
      "default": "infinite_scroll"
    }
  ]
}
{% endschema %}
