<section class="ff-site">
  <div class="ff-wrap ff-wrap--page">
    {% render 'ff-min-nav', active: 'contact', class: 'ff-header--page' %}

    <div class="ff-content-box">
      <div class="ff-contact-inner">
        {% form 'contact', class: 'ff-contact-form' %}

          {% if form.posted_successfully? %}
            <p style="margin-bottom:20px;font-size:16px;">Thank you — we'll get back to you shortly.</p>
          {% endif %}

          {% if form.errors %}
            <div class="ff-form-error" style="margin-bottom:16px;">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="ff-form-row">
            <input
              class="ff-input"
              type="text"
              name="contact[first_name]"
              placeholder="First Name"
              value="{{ form.first_name }}">
            <input
              class="ff-input"
              type="text"
              name="contact[last_name]"
              placeholder="Last Name"
              value="{{ form.last_name }}">
          </div>

          <div class="ff-form-row">
            <input
              class="ff-input"
              type="email"
              name="contact[email]"
              placeholder="Email Address"
              value="{{ form.email }}"
              required>
            <input
              class="ff-input"
              type="text"
              name="contact[order_number]"
              placeholder="Order Number"
              value="{{ form.order_number }}">
          </div>

          <input
            class="ff-input"
            type="text"
            name="contact[subject]"
            placeholder="Subject"
            value="{{ form.subject }}">

          <textarea
            class="ff-textarea"
            name="contact[body]"
            placeholder="Message"
            required>{{ form.body }}</textarea>

          <div class="ff-form-buttons">
            <a class="ff-btn" href="{{ routes.root_url }}">Back Home</a>
            <button class="ff-btn" type="submit">Send</button>
          </div>

        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FF Minimal Contact",
  "settings": [],
  "presets": [
    {
      "name": "FF Minimal Contact"
    }
  ]
}
{% endschema %}
