{%- liquid
  assign primary_variant = product.selected_or_first_available_variant
  assign gallery_media = product.media | where: 'media_type', 'image'
  assign primary_media = product.featured_media
  if primary_media == blank and gallery_media.size > 0
    assign primary_media = gallery_media.first
  endif

  assign size_chart_url = '/pages/size-chart'
  if pages['size-chart'] != blank
    assign size_chart_url = pages['size-chart'].url
  endif
-%}

<div class="ff-shell">
  {% render 'ff-site-nav', variant: 'page' %}

  <main class="ff-page-wrap">
    <div class="ff-product-layout">
      <section>
        {% if primary_media %}
          <div class="ff-product-gallery-main">
            <img
              src="{{ primary_media | image_url: width: 1800 }}"
              srcset="{{ primary_media | image_url: width: 540 }} 540w, {{ primary_media | image_url: width: 900 }} 900w, {{ primary_media | image_url: width: 1400 }} 1400w, {{ primary_media | image_url: width: 1800 }} 1800w"
              sizes="(max-width: 900px) 100vw, 55vw"
              alt="{{ primary_media.alt | default: product.title | escape }}"
              loading="eager">
          </div>
        {% endif %}

        {% if gallery_media.size > 1 %}
          <div class="ff-product-gallery-strip">
            {%- assign shown_thumbs = 0 -%}
            {% for media in gallery_media %}
              {% if primary_media and media.id == primary_media.id %}
                {% continue %}
              {% endif %}
              {% if shown_thumbs >= 3 %}
                {% break %}
              {% endif %}
              <div class="ff-product-gallery-thumb">
                <img
                  src="{{ media | image_url: width: 900 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  loading="lazy">
              </div>
              {%- assign shown_thumbs = shown_thumbs | plus: 1 -%}
            {% endfor %}
          </div>
        {% endif %}
      </section>

      <section>
        <h1 class="ff-product-heading">{{ product.title }}</h1>
        <p class="ff-product-price-large">{{ primary_variant.price | money }}</p>

        <div class="ff-product-copy">
          {{ product.description }}
        </div>

        {% if product.metafields.custom.characteristics != blank or section.settings.default_features != blank %}
          <h2 class="ff-feature-title">Features</h2>

          {% if product.metafields.custom.characteristics != blank %}
            <div class="ff-product-copy">
              {{ product.metafields.custom.characteristics | metafield_tag }}
            </div>
          {% else %}
            {% assign feature_lines = section.settings.default_features | newline_to_br | split: '<br />' %}
            <ul class="ff-feature-list">
              {% for feature in feature_lines %}
                {% assign cleaned_feature = feature | strip %}
                {% if cleaned_feature != blank %}
                  <li>{{ cleaned_feature }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}

        {% form 'product', product, class: 'ff-product-form' %}
          <div class="ff-size-row">
            <p class="ff-size-label">Taille FR/EU</p>
            <a href="{{ size_chart_url }}" class="ff-size-chart">size chart</a>
          </div>

          {% if product.variants.size > 1 %}
            <select name="id" class="ff-select" aria-label="Size selector">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}"{% if variant.id == primary_variant.id %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                  {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ primary_variant.id }}">
          {% endif %}

          <button type="submit" class="ff-add-btn"{% unless primary_variant.available %} disabled{% endunless %}>
            {% if primary_variant.available %}
              Ajouter au panier
            {% else %}
              Indisponible
            {% endif %}
          </button>
        {% endform %}

        <details class="ff-accordion">
          <summary>Shipping information</summary>
          <div class="ff-accordion-body">
            {{ section.settings.shipping_information | newline_to_br }}
          </div>
        </details>

        <details class="ff-accordion">
          <summary>Care instructions</summary>
          <div class="ff-accordion-body">
            {% if product.metafields.custom.care_instructions != blank %}
              {{ product.metafields.custom.care_instructions | metafield_tag }}
            {% else %}
              {{ section.settings.care_instructions | newline_to_br }}
            {% endif %}
          </div>
        </details>
      </section>
    </div>
  </main>
</div>

{% schema %}
{
  "name": "FF Product Detail",
  "settings": [
    {
      "type": "textarea",
      "id": "default_features",
      "label": "Fallback bullet features (one line per bullet)",
      "default": "Premium textile\nCoupe ajustee\nFabrication en petite serie"
    },
    {
      "type": "textarea",
      "id": "shipping_information",
      "label": "Shipping information",
      "default": "Products are made to order. Shipping usually occurs between 1 and 4 weeks after order confirmation."
    },
    {
      "type": "textarea",
      "id": "care_instructions",
      "label": "Care instructions",
      "default": "Wash inside out at low temperature. Do not tumble dry. Iron on low heat."
    }
  ],
  "presets": [
    {
      "name": "FF Product Detail"
    }
  ]
}
{% endschema %}
