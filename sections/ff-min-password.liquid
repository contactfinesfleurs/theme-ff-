<section class="ff-password">
  <div class="ff-password-card">
    <h1 class="ff-password-title">FINES FLEURS</h1>

    <p class="ff-password-subtitle">
      {{ shop.password_message | default: section.settings.message }}
    </p>

    {% form 'storefront_password', class: 'ff-password-form' %}
      <div class="ff-password-actions">
        <input class="ff-input" type="password" name="password" id="ff-password" placeholder="Enter password" autocomplete="current-password">
        <button class="ff-add-to-cart" type="submit">Enter</button>
      </div>

      {% if form.errors %}
        <p class="ff-form-error">Incorrect password.</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "FF Minimal Password",
  "settings": [
    {
      "type": "textarea",
      "id": "message",
      "label": "Default message",
      "default": "The store is currently private for maintenance and exclusive previews."
    }
  ]
}
{% endschema %}
