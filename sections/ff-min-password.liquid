<section class="ff-password-page">
  <h1 class="ff-password-logo">FINES FLEURS</h1>

  <div class="ff-countdown-block">
    <p class="ff-countdown-label">the next collection will drop in</p>

    <div class="ff-countdown">
      <div class="ff-countdown-unit">
        <div class="ff-countdown-box" id="ff-days">—</div>
        <span class="ff-countdown-unit-label">days</span>
      </div>
      <div class="ff-countdown-unit">
        <div class="ff-countdown-box" id="ff-hours">—</div>
        <span class="ff-countdown-unit-label">hours</span>
      </div>
      <div class="ff-countdown-unit">
        <div class="ff-countdown-box" id="ff-mins">—</div>
        <span class="ff-countdown-unit-label">min</span>
      </div>
      <div class="ff-countdown-unit">
        <div class="ff-countdown-box" id="ff-secs">—</div>
        <span class="ff-countdown-unit-label">sec</span>
      </div>
    </div>
  </div>

  <div class="ff-email-block">
    <p class="ff-email-label">enter your email to gain exclusivity</p>
    {% form 'customer' %}
      <input type="hidden" name="customer[tags]" value="newsletter,early-access">
      <input
        class="ff-email-input"
        type="email"
        name="customer[email]"
        placeholder="e-mail"
        required
        autocomplete="email">
      {% if form.posted_successfully? %}
        <p style="margin-top:12px;font-size:14px;color:var(--ff-muted);">Thank you — you're on the list.</p>
      {% endif %}
      {% if form.errors %}
        <p style="margin-top:12px;font-size:14px;color:#b00020;">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

<script>
  (function () {
    var launch = new Date("{{ section.settings.launch_date }}T00:00:00");
    function tick() {
      var diff = launch - new Date();
      if (diff <= 0) {
        ["ff-days","ff-hours","ff-mins","ff-secs"].forEach(function(id){
          var el = document.getElementById(id);
          if (el) el.textContent = "0";
        });
        return;
      }
      var days  = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var mins  = Math.floor((diff % 3600000)  / 60000);
      var secs  = Math.floor((diff % 60000)    / 1000);
      var el;
      el = document.getElementById("ff-days");  if (el) el.textContent = days;
      el = document.getElementById("ff-hours"); if (el) el.textContent = String(hours).padStart(2,"0");
      el = document.getElementById("ff-mins");  if (el) el.textContent = String(mins).padStart(2,"0");
      el = document.getElementById("ff-secs");  if (el) el.textContent = String(secs).padStart(2,"0");
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

{% schema %}
{
  "name": "FF Minimal Password",
  "settings": [
    {
      "type": "text",
      "id": "launch_date",
      "label": "Launch date (YYYY-MM-DD)",
      "default": "2025-09-01",
      "info": "Countdown target date in ISO format, e.g. 2025-09-01"
    }
  ]
}
{% endschema %}
