{%- comment -%}
  Password Page — Clean Tailwind layout with logo, countdown, email signup
  Keeps existing countdown JS via data attributes
{%- endcomment -%}

{%- assign pjCnfg = section.settings -%}

<div class="flex flex-col items-center justify-center min-h-screen px-6 py-12 bg-white">

  {%- comment -%} Logo {%- endcomment -%}
  <div class="mb-10">
    {% if settings.password_screen_logo %}
      <img
        src="{{ settings.password_screen_logo | image_url: width: 500 }}"
        srcset="{{ settings.password_screen_logo | image_url: width: 250 }} 250w, {{ settings.password_screen_logo | image_url: width: 500 }} 500w"
        sizes="(max-width: 640px) 180px, 250px"
        alt="{{ shop.name | escape }}"
        class="w-44 sm:w-60 h-auto mx-auto"
        loading="eager">
    {% elsif settings.shop_screen_logo %}
      <img
        src="{{ settings.shop_screen_logo | image_url: width: 500 }}"
        srcset="{{ settings.shop_screen_logo | image_url: width: 250 }} 250w, {{ settings.shop_screen_logo | image_url: width: 500 }} 500w"
        sizes="(max-width: 640px) 180px, 250px"
        alt="{{ shop.name | escape }}"
        class="w-44 sm:w-60 h-auto mx-auto"
        loading="eager">
    {% else %}
      <h1 class="text-3xl sm:text-4xl font-bold tracking-[0.2em] uppercase text-center">FINES FLEURS</h1>
    {% endif %}
  </div>

  {%- comment -%} Tagline {%- endcomment -%}
  {% if section.settings.tagline != blank %}
    <p class="text-sm sm:text-base text-center text-black font-medium tracking-wide mb-2 max-w-md">
      {{ section.settings.tagline }}
    </p>
  {% endif %}

  {%- comment -%} Countdown intro text {%- endcomment -%}
  {% if section.settings.countdown_intro != blank %}
    <p class="text-xs sm:text-sm text-center text-gray-500 uppercase tracking-wider mb-6">
      {{ section.settings.countdown_intro }}
    </p>
  {% endif %}

  {%- comment -%} Countdown Timer {%- endcomment -%}
  <div class="countdown-timer flex items-start justify-center gap-4 sm:gap-6 mb-12"
       cMonth="{{ pjCnfg.countdown_month }}"
       cDay="{{ pjCnfg.countdown_day }}"
       cYear="{{ pjCnfg.countdown_year }}"
       cHour="{{ pjCnfg.countdown_hour }}"
       cMin="{{ pjCnfg.countdown_min }}"
       cAMmPm="{{ pjCnfg.countdown_ampm }}"
       disableCountdownAnimation="true">

    <div class="countdown-box flex flex-col items-center">
      <p id="days" class="countdown-value text-3xl sm:text-5xl font-light text-black tabular-nums"></p>
      <p class="countdown-metric text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mt-1">days</p>
    </div>

    <span class="text-2xl sm:text-4xl font-light text-gray-300 mt-0.5">:</span>

    <div class="countdown-box flex flex-col items-center">
      <p id="hours" class="countdown-value text-3xl sm:text-5xl font-light text-black tabular-nums"></p>
      <p class="countdown-metric text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mt-1">hours</p>
    </div>

    <span class="text-2xl sm:text-4xl font-light text-gray-300 mt-0.5">:</span>

    <div class="countdown-box flex flex-col items-center">
      <p id="minutes" class="countdown-value text-3xl sm:text-5xl font-light text-black tabular-nums"></p>
      <p class="countdown-metric text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mt-1">min</p>
    </div>

    <span class="text-2xl sm:text-4xl font-light text-gray-300 mt-0.5">:</span>

    <div class="countdown-box flex flex-col items-center">
      <p id="seconds" class="countdown-value text-3xl sm:text-5xl font-light text-black tabular-nums"></p>
      <p class="countdown-metric text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mt-1">sec</p>
    </div>
  </div>

  {%- comment -%} Email Signup {%- endcomment -%}
  <div class="w-full max-w-md mb-10">
    <p class="text-xs text-center text-gray-500 uppercase tracking-wider mb-4">
      {{ section.settings.email_heading | default: 'enter your email to gain exclusivity' }}
    </p>
    {%- form 'customer', class: 'flex flex-col sm:flex-row gap-2' -%}
      <input type="hidden" name="customer[tags]" value="password-page,newsletter">
      <input type="hidden" name="customer[accepts_marketing]" value="true">
      <input
        type="email"
        name="customer[email]"
        placeholder="Email"
        required
        class="flex-1 border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
      <button
        type="submit"
        class="bg-black text-white text-xs uppercase tracking-widest px-6 py-3 hover:bg-gray-800 transition-colors cursor-pointer border-none whitespace-nowrap">
        {{ section.settings.email_btn_text | default: 'Subscribe' }}
      </button>
    {%- endform -%}
  </div>

  {%- comment -%} Password Entry (small link) {%- endcomment -%}
  <div class="mt-4">
    <button id="password-toggle" class="text-xs text-gray-400 hover:text-black transition-colors underline cursor-pointer bg-transparent border-none">
      {{ section.settings.password_link_text | default: 'Enter with password' }}
    </button>
  </div>

  {%- comment -%} Password Modal {%- endcomment -%}
  <div id="password-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center" style="background: rgba(0,0,0,0.3); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">
    <div class="bg-white p-8 sm:p-10 max-w-sm w-full mx-4 relative">
      <button id="password-close" class="absolute top-3 right-4 text-gray-400 hover:text-black text-xl cursor-pointer bg-transparent border-none">&times;</button>
      <p class="text-sm text-center text-black uppercase tracking-wider mb-6">Enter password</p>
      {%- form 'storefront_password', class: 'space-y-3' -%}
        <input
          name="password"
          type="password"
          placeholder="*****"
          class="w-full border border-gray-300 px-4 py-3 text-sm bg-white text-black placeholder-gray-400 focus:outline-none focus:border-black transition-colors">
        <input
          type="submit"
          value="Enter"
          class="w-full bg-black text-white text-xs uppercase tracking-widest py-3 hover:bg-gray-800 transition-colors cursor-pointer border-none">
      {%- endform -%}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var toggleBtn = document.getElementById('password-toggle');
  var modal = document.getElementById('password-modal');
  var closeBtn = document.getElementById('password-close');
  if (toggleBtn && modal) {
    toggleBtn.addEventListener('click', function() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      });
    }
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });
  }
});
</script>

{{ 'password-countdown-section.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Password Content",
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "\"MORE THAN YESTERDAY, LESS THAN TOMORROW\""
    },
    {
      "type": "text",
      "id": "countdown_intro",
      "label": "Countdown Intro Text",
      "default": "the next collection will drop in"
    },
    {
      "type": "header",
      "content": "Countdown Timer (UTC)"
    },
    {
      "type": "select",
      "id": "countdown_month",
      "label": "Month",
      "options": [
        { "value": "Jan", "label": "Jan" },
        { "value": "Feb", "label": "Feb" },
        { "value": "Mar", "label": "Mar" },
        { "value": "Apr", "label": "Apr" },
        { "value": "May", "label": "May" },
        { "value": "Jun", "label": "Jun" },
        { "value": "Jul", "label": "Jul" },
        { "value": "Aug", "label": "Aug" },
        { "value": "Sep", "label": "Sep" },
        { "value": "Oct", "label": "Oct" },
        { "value": "Nov", "label": "Nov" },
        { "value": "Dec", "label": "Dec" }
      ],
      "default": "Sep"
    },
    {
      "type": "range",
      "id": "countdown_day",
      "min": 1,
      "max": 31,
      "step": 1,
      "label": "Day",
      "default": 19
    },
    {
      "type": "range",
      "id": "countdown_year",
      "min": 2024,
      "max": 2083,
      "step": 1,
      "label": "Year",
      "default": 2026
    },
    {
      "type": "number",
      "id": "countdown_hour",
      "label": "Hour",
      "default": 12
    },
    {
      "type": "number",
      "id": "countdown_min",
      "label": "Minute",
      "default": 0
    },
    {
      "type": "select",
      "id": "countdown_ampm",
      "label": "AM or PM",
      "options": [
        { "value": "am", "label": "AM" },
        { "value": "pm", "label": "PM" }
      ],
      "default": "am"
    },
    {
      "type": "header",
      "content": "Email Signup"
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email Heading",
      "default": "enter your email to gain exclusivity"
    },
    {
      "type": "text",
      "id": "email_btn_text",
      "label": "Button Text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Password Link"
    },
    {
      "type": "text",
      "id": "password_link_text",
      "label": "Password Link Text",
      "default": "Enter with password"
    }
  ],
  "presets": [
    {
      "name": "Password Content"
    }
  ]
}
{% endschema %}
