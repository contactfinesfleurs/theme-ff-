{%- comment -%}
  Homepage Hero — horizontal logo + menu layout matching the provided target.
{%- endcomment -%}

{%- assign section_scope = 'ff-home-' | append: section.id -%}

<section class="{{ section_scope }}">
  <div class="{{ section_scope }}__inner">
    <a href="{{ routes.root_url }}" class="{{ section_scope }}__logo-link">
      {% if settings.enter_screen_logo %}
        <img
          src="{{ settings.enter_screen_logo | image_url: width: 700 }}"
          srcset="{{ settings.enter_screen_logo | image_url: width: 320 }} 320w, {{ settings.enter_screen_logo | image_url: width: 700 }} 700w"
          sizes="(max-width: 740px) 180px, (max-width: 1200px) 220px, 280px"
          alt="{{ shop.name | escape }}"
          class="{{ section_scope }}__logo-image"
          loading="eager"
          decoding="sync"
          fetchpriority="high">
      {% else %}
        <span class="{{ section_scope }}__logo-text">FINES FLEURS</span>
      {% endif %}
    </a>

    <nav class="{{ section_scope }}__nav" aria-label="Main navigation">
      <a href="{{ routes.root_url }}" class="{{ section_scope }}__link {{ section_scope }}__link--active">home</a>
      <a href="{% if collections['all'] %}{{ collections['all'].url }}{% else %}/collections/all{% endif %}" class="{{ section_scope }}__link">shop</a>
      <a href="/pages/about" class="{{ section_scope }}__link">us</a>
      <a href="/pages/contact" class="{{ section_scope }}__link">contact</a>
    </nav>
  </div>
</section>

<style>
  .{{ section_scope }} {
    position: relative;
    z-index: 3;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .{{ section_scope }}__inner {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0 clamp(34px, 5.45vw, 92px);
    display: flex;
    align-items: center;
  }

  .{{ section_scope }}__logo-link {
    flex: 0 0 auto;
    color: #111;
    text-decoration: none;
    line-height: 0;
  }

  .{{ section_scope }}__logo-image {
    width: auto;
    height: clamp(58px, 4.35vw, 74px);
    display: block;
  }

  .{{ section_scope }}__logo-text {
    display: inline-block;
    font-family: var(--font_header), "Bebas Neue", "Oswald", sans-serif;
    font-size: clamp(3.65rem, 4.35vw, 4.65rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: 0.008em;
    text-transform: uppercase;
  }

  .{{ section_scope }}__nav {
    display: flex;
    align-items: center;
    margin-left: clamp(120px, 18vw, 322px);
    gap: clamp(54px, 5.6vw, 96px);
  }

  .{{ section_scope }}__link {
    position: relative;
    padding-bottom: 0.58em;
    color: #171717;
    font-family: "DM Sans", sans-serif;
    font-size: clamp(1.62rem, 1.8vw, 1.95rem);
    font-weight: 500;
    line-height: 1;
    text-transform: lowercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .{{ section_scope }}__link:hover {
    color: #171717;
  }

  .{{ section_scope }}__link--active {
    color: #171717;
  }

  .{{ section_scope }}__link--active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: #6f6f6f;
  }

  @media (max-width: 1200px) {
    .{{ section_scope }}__inner {
      padding-left: clamp(26px, 4.2vw, 56px);
      padding-right: clamp(26px, 4.2vw, 56px);
    }

    .{{ section_scope }}__logo-image {
      height: clamp(48px, 5.2vw, 62px);
    }

    .{{ section_scope }}__logo-text {
      font-size: clamp(2.6rem, 5.9vw, 3.7rem);
    }

    .{{ section_scope }}__nav {
      margin-left: clamp(44px, 9vw, 122px);
      gap: clamp(22px, 3.4vw, 58px);
    }

    .{{ section_scope }}__link {
      font-size: clamp(1.1rem, 2.45vw, 1.55rem);
      padding-bottom: 0.5em;
    }
  }

  @media (max-width: 760px) {
    .{{ section_scope }} {
      justify-content: center;
      padding: 20px 0;
    }

    .{{ section_scope }}__inner {
      flex-direction: column;
      row-gap: 20px;
      text-align: center;
      justify-content: center;
      padding-left: 20px;
      padding-right: 20px;
    }

    .{{ section_scope }}__nav {
      margin-left: 0;
    }

    .{{ section_scope }}__logo-image {
      height: clamp(38px, 12vw, 52px);
      width: auto;
    }

    .{{ section_scope }}__logo-text {
      font-size: clamp(2.2rem, 11vw, 3.2rem);
    }

    .{{ section_scope }}__nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px 20px;
    }

    .{{ section_scope }}__link {
      font-size: clamp(1rem, 4.95vw, 1.26rem);
      padding-bottom: 0.44em;
    }

  }
</style>

{% schema %}
{
  "name": "Homepage Hero",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Full-page landing layout. Logo and navigation are centered vertically on the page. Logo is configured in Theme Settings > Logo."
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
