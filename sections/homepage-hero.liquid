{%- comment -%}
  Homepage Hero — Clean minimal landing page with centered logo
{%- endcomment -%}

<div class="flex items-center justify-center" style="min-height: calc(100vh - 80px);">
  <div class="flex items-center justify-center gap-5 sm:gap-7 px-6">
    {% if settings.enter_screen_logo %}
      <img
        src="{{ settings.enter_screen_logo | image_url: width: 300 }}"
        srcset="{{ settings.enter_screen_logo | image_url: width: 150 }} 150w, {{ settings.enter_screen_logo | image_url: width: 300 }} 300w"
        sizes="(max-width: 640px) 60px, 80px"
        alt="{{ shop.name | escape }}"
        class="h-14 sm:h-16 md:h-20 w-auto flex-shrink-0"
        loading="eager"
        decoding="sync"
        fetchpriority="high">
    {% endif %}
    <span class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-[0.2em] uppercase">
      FINES FLEURS
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Homepage Hero",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays the store logo centered on a clean white background. Logo is configured in Theme Settings > Logo."
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
