{%- comment -%}
  About Us — Clean centered layout with logo and brand description
{%- endcomment -%}

<div class="max-w-3xl mx-auto px-6 sm:px-10 py-16 sm:py-24">
  <div class="border border-gray-200 px-8 sm:px-16 py-12 sm:py-20">

    {%- comment -%} Logo {%- endcomment -%}
    <div class="flex justify-center mb-8">
      {% if settings.enter_screen_logo %}
        <img
          src="{{ settings.enter_screen_logo | image_url: width: 400 }}"
          srcset="{{ settings.enter_screen_logo | image_url: width: 200 }} 200w, {{ settings.enter_screen_logo | image_url: width: 400 }} 400w"
          sizes="(max-width: 640px) 150px, 200px"
          alt="{{ shop.name | escape }}"
          class="w-36 sm:w-48 h-auto"
          loading="lazy">
      {% else %}
        <h2 class="text-2xl sm:text-3xl font-bold tracking-[0.2em] uppercase">FINES FLEURS</h2>
      {% endif %}
    </div>

    {%- comment -%} Subtitle {%- endcomment -%}
    <h3 class="text-center text-sm uppercase tracking-[0.15em] text-gray-500 mb-8">
      {{ section.settings.subtitle | default: 'about us' }}
    </h3>

    {%- comment -%} Content — editable from Shopify admin via page.content {%- endcomment -%}
    <div class="text-center text-sm sm:text-base text-gray-700 leading-relaxed space-y-4">
      {% if page.content != blank %}
        {{ page.content }}
      {% else %}
        {{ section.settings.about_text }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Us Content",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "about us"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About Text (fallback if page has no content)",
      "default": "<p>Your brand story goes here.</p>"
    }
  ],
  "presets": [
    {
      "name": "About Us Content"
    }
  ]
}
{% endschema %}
