<div class="ff-shell">
  {% render 'ff-site-nav', variant: 'page' %}

  <main class="ff-static-wrap">
    <h1 class="ff-static-title">{{ policy.title | default: page.title | default: section.settings.fallback_title }}</h1>

    <div class="ff-static-content">
      {% if policy and policy.body != blank %}
        {{ policy.body }}
      {% elsif page.content != blank %}
        {{ page.content }}
      {% else %}
        {{ section.settings.fallback_content }}
      {% endif %}
    </div>
  </main>
</div>

{% schema %}
{
  "name": "FF Policy Content",
  "settings": [
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "terms & refund"
    },
    {
      "type": "richtext",
      "id": "fallback_content",
      "label": "Fallback content",
      "default": "<p>Add your policy content from Shopify Admin > Settings > Policies.</p>"
    }
  ],
  "presets": [
    {
      "name": "FF Policy Content"
    }
  ]
}
{% endschema %}
