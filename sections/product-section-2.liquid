{%- comment -%}
  Product Section — Clean Tailwind two-column layout
  Left: Featured image + thumbnail gallery
  Right: Title, price, description, size selector, add to cart, accordions
{%- endcomment -%}

<style>
  .product-fade-in { animation: productFadeIn 0.6s ease forwards; }
  @keyframes productFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  /* Accordion */
  .product-accordion-toggle { display: none; }
  .product-accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .product-accordion-toggle:checked ~ .product-accordion-content { max-height: 500px; }
  .product-accordion-toggle:checked ~ .product-accordion-header .accordion-arrow { transform: rotate(180deg); }
  .accordion-arrow { transition: transform 0.3s ease; }
  /* Gallery thumbnail active */
  .thumb-item { opacity: 0.6; transition: opacity 0.2s ease; }
  .thumb-item:hover, .thumb-item.active { opacity: 1; }
  /* Fullscreen gallery styles are defined in theme.liquid */
</style>

<div class="product-fade-in max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-10 py-8 sm:py-12">
  <div
    id="product-data"
    shop-price-format='{{ shop.money_format }}'
    shop-price-format-with-currency='{{ shop.money_with_currency_format }}'
    data-product="{{ product | json | escape }}"
    class="flex flex-col lg:flex-row gap-8 lg:gap-12">

    {%- comment -%} LEFT COLUMN — Images {%- endcomment -%}
    <div class="w-full lg:w-[58%]">
      {%- comment -%} Featured Image {%- endcomment -%}
      <div class="featured-product-image cursor-zoom-in aspect-[3/4] overflow-hidden bg-gray-50">
        {% render 'product-media-main', media: product.featured_media %}
      </div>

      {%- comment -%} Thumbnail Gallery {%- endcomment -%}
      {% if product.media.size >= 2 %}
        <div class="grid grid-cols-4 gap-2 mt-3">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <div class="thumb-item {% if forloop.first %}active{% endif %} aspect-[3/4] overflow-hidden bg-gray-50 cursor-pointer">
                <img
                  src="{{ media.preview_image | img_url: '200x' }}"
                  alt="{{ media.preview_image.alt | escape }}"
                  class="w-full h-full object-cover"
                  loading="lazy">
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {%- comment -%} RIGHT COLUMN — Product Info {%- endcomment -%}
    <div class="w-full lg:w-[42%] flex flex-col">
      {%- for block in section.blocks -%}
        {% case block.type %}

          {%- comment -%} ON SALE LABEL {%- endcomment -%}
          {% when 'on_sale_label' %}
            {% if product.compare_at_price > 0 %}
              <div class="inline-block bg-black text-white text-[10px] uppercase tracking-wider px-2 py-0.5 mb-2">
                {{ 'products.product.on_sale' | t }}
              </div>
            {% endif %}

          {%- comment -%} PRODUCT TITLE {%- endcomment -%}
          {% when 'product_header' %}
            <h1 class="product-title text-lg sm:text-xl font-medium text-black tracking-wide mb-1">
              {{ product.title }}
            </h1>

          {%- comment -%} PRICE {%- endcomment -%}
          {% when 'product_price' %}
            <div class="mb-4">
              <p class="price current-price text-sm text-gray-700" id="product-price-section-2"
                 addCurrency="{% if block.settings.currency_format == 'with_currency' %}true{% endif %}">
                {% if block.settings.currency_format == 'with_currency' %}
                  {{ product.selected_variant.price | default: product.price | money_with_currency }}
                {% else %}
                  {{ product.selected_variant.price | default: product.price | money }}
                {% endif %}
              </p>
              {% if product.compare_at_price > 0 %}
                <div class="compare-price-container flex items-center gap-2 mt-1">
                  <span class="text-xs text-gray-500">{{ 'products.product.was' | t }}:</span>
                  <span class="price sale text-xs text-red-500 line-through">
                    {{ product.compare_at_price | money }}
                  </span>
                </div>
              {% endif %}
            </div>

          {%- comment -%} DESCRIPTION {%- endcomment -%}
          {% when 'product_description' %}
            <div class="product-description description text-sm text-gray-700 leading-relaxed mb-6 prose prose-sm max-w-none" id="product-description">
              {{ product.description }}
            </div>

          {%- comment -%} GALLERY (hidden — thumbnails are in left column now) {%- endcomment -%}
          {% when 'product_gallery' %}
            {%- comment -%} Gallery is now integrated into the left column {%- endcomment -%}

          {%- comment -%} VARIATIONS / ADD TO CART {%- endcomment -%}
          {% when 'product_variations' %}
            <div id="add-to-cart-section" class="mb-6">
              <div class="add-to-cart">
                {%- form 'product', product, data-node-type: 'commerce-add-to-cart-form', class: 'w-commerce-commerceaddtocartform default-state' -%}
                  {% if product.available %}
                    <div data-node-type="add-to-cart-option-list">
                      {%- for option in product.options_with_values -%}
                        {%- comment -%} Size label row {%- endcomment -%}
                        <div class="flex items-center justify-between mb-2 {% if product.has_only_default_variant or product.variants.size == 0 %}hidden{% endif %}">
                          <span class="text-xs text-gray-500 uppercase tracking-wider">{{ option.name }}{% if option.name == 'Size' or option.name == 'Taille' %} FR/EU{% endif %}</span>
                          {% if option.name == 'Size' or option.name == 'Taille' %}
                            <a href="#" class="text-xs text-gray-400 underline hover:text-black transition-colors">size chart</a>
                          {% endif %}
                        </div>
                        <fieldset data-node-type="add-to-cart-option" class="mb-3 {% if product.has_only_default_variant or product.variants.size == 0 %}hidden{% endif %}">
                          <select
                            data-node-type="add-to-cart-option-select"
                            class="variant-select select-field w-select w-full border border-gray-300 px-3 py-2.5 text-sm bg-white text-black focus:outline-none focus:border-black transition-colors appearance-none"
                            name="{{ 'option' | append: forloop.index }}">
                            {%- render 'product-options', option: option -%}
                          </select>
                          <div data-node-type="add-to-cart-option-pill-group" class="w-commerce-commerceaddtocartoptionpillgroup hidden" aria-label="{{ 'option' | append: forloop.index }}">
                            {%- for value in option.values -%}
                              <div data-node-type="add-to-cart-option-pill" class="w-commerce-commerceaddtocartoptionpill" data-option-name="{{ value | handle }}">
                                <div data-node-type="block">{{ value }}</div>
                              </div>
                            {%- endfor -%}
                          </div>
                        </fieldset>
                      {%- endfor -%}
                    </div>
                  {% endif %}

                  {% if product.available %}
                    <input
                      type="submit"
                      data-node-type="commerce-add-to-cart-button"
                      value="{{ 'products.product.add_to_cart' | t }}"
                      aria-busy="false"
                      aria-haspopup="dialog"
                      class="w-commerce-commerceaddtocartbutton add-to-cart-button w-full bg-black text-white text-sm uppercase tracking-widest py-3.5 mt-2 hover:bg-gray-800 transition-colors cursor-pointer border-none">
                  {% endif %}

                  {%- render 'product-variants-data', product: product -%}
                {%- endform -%}

                {% if product.available == false %}
                  <div class="sold-out-product-btn-2 w-full bg-gray-400 text-white text-sm uppercase tracking-widest py-3.5 mt-2 text-center">
                    {{ 'products.product.sold_out' | t }}
                  </div>
                {% endif %}

                <div class="sold-out-product-btn w-full bg-gray-400 text-white text-sm uppercase tracking-widest py-3.5 mt-2 text-center" style="display:none" tabindex="0">
                  {{ 'products.product.sold_out' | t }}
                </div>

                <div aria-live="assertive" data-node-type="commerce-add-to-cart-error" style="display:none" class="w-commerce-commerceaddtocarterror mt-2 text-sm text-red-500">
                  <div
                    data-node-type="commerce-add-to-cart-error"
                    data-w-add-to-cart-quantity-error="{{ 'products.product.not_available_in_this_quantity' | t }}"
                    data-w-add-to-cart-general-error="{{ 'products.product.something_went_wrong' | t }}"
                    data-w-add-to-cart-mixed-cart-error="{{ 'products.product.cant_purchase_another_product_with_subscription' | t }}"
                    data-w-add-to-cart-buy-now-error="{{ 'products.product.something_went_wrong_when_trying_to_purchase_this_item' | t }}"
                    data-w-add-to-cart-checkout-disabled-error="{{ 'products.product.checkout_is_disabled_on_this_site' | t }}"
                    data-w-add-to-cart-select-all-options-error="{{ 'products.product.please_select_an_option_in_each_set' | t }}">
                    {{ 'products.product.error_occurred' | t }}
                  </div>
                </div>
              </div>

              {%- comment -%} Keep Shopping link {%- endcomment -%}
              <a href="{% if collection %}{{ collection.url }}{% elsif product.collections.first %}{{ product.collections.first.url }}{% else %}/collections/all{% endif %}"
                 class="block text-center text-xs text-gray-400 mt-3 hover:text-black transition-colors underline">
                {{ 'products.product.keep_shopping' | t }}
              </a>
            </div>

          {%- comment -%} ACCORDION {%- endcomment -%}
          {% when 'product_accordion' %}
            <div class="border-t border-gray-200">
              <input type="checkbox" id="accordion-{{ block.id }}" class="product-accordion-toggle">
              <label for="accordion-{{ block.id }}" class="product-accordion-header flex items-center justify-between py-3 cursor-pointer group">
                <span class="text-sm text-black">{{ block.settings.accordion_title }}</span>
                <svg class="accordion-arrow w-4 h-4 text-gray-400 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </label>
              <div class="product-accordion-content">
                <div class="pb-4 text-sm text-gray-600 leading-relaxed">
                  {{ block.settings.accordion_description }}
                  {{ block.settings.accordion_page.content }}
                  {% if block.settings.accordion_title contains 'Care' %}
                    {{ product.metafields.custom.care_guide | metafield_tag }}
                  {% endif %}
                </div>
              </div>
            </div>

        {% endcase %}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- comment -%} Sticky Button {%- endcomment -%}
{% if section.settings.show_sticky_button %}
<div id="sticky-product-btn" class="fixed bottom-5 right-5 z-[999] opacity-0 translate-y-5 transition-all duration-300 pointer-events-none">
  {% if product.available %}
    <button type="button" id="sticky-add-to-cart"
      class="bg-black text-white border-none px-7 py-3.5 text-sm uppercase tracking-wider shadow-lg hover:bg-gray-800 transition-colors cursor-pointer">
      {{ section.settings.sticky_btn_text_available | default: 'Commander' }}
    </button>
  {% else %}
    <button type="button" id="sticky-notify-me"
      class="bg-red-600 text-white border-none px-7 py-3.5 text-sm uppercase tracking-wider shadow-lg hover:bg-red-700 transition-colors cursor-pointer">
      {{ section.settings.sticky_btn_text_unavailable | default: 'Me prevenir' }}
    </button>
  {% endif %}
</div>
{% endif %}

<script>
  var productDataEl = document.getElementById('product-data');
  if (productDataEl) {
    window.product = JSON.parse(productDataEl.getAttribute('data-product'));
  }
</script>
<script src="{{ 'product-item-zoom.js' | asset_url }}" type="text/javascript"></script>
<script src="{{ 'money-format-handler.js' | asset_url }}" type="text/javascript"></script>
<script src="{{ 'product-item-sync-raw.js' | asset_url }}" type="text/javascript"></script>
<script src="{{ 'plain-jane-2.js' | asset_url }}" type="text/javascript"></script>
<script src="{{ 'udesly-shopify.min.js' | asset_url }}" type="text/javascript"></script>
<script src="{{ 'product-add-to-cart.js' | asset_url }}" defer></script>

{% if section.settings.show_sticky_button %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  var stickyBtn = document.getElementById('sticky-product-btn');
  var addToCartSection = document.getElementById('add-to-cart-section');
  if (!stickyBtn) return;

  function toggleStickyBtn() {
    if (!addToCartSection) {
      stickyBtn.style.opacity = '1';
      stickyBtn.style.transform = 'translateY(0)';
      stickyBtn.style.pointerEvents = 'auto';
      return;
    }
    var rect = addToCartSection.getBoundingClientRect();
    var isOutOfView = rect.bottom < 0 || rect.top > window.innerHeight;
    if (isOutOfView) {
      stickyBtn.style.opacity = '1';
      stickyBtn.style.transform = 'translateY(0)';
      stickyBtn.style.pointerEvents = 'auto';
    } else {
      stickyBtn.style.opacity = '0';
      stickyBtn.style.transform = 'translateY(20px)';
      stickyBtn.style.pointerEvents = 'none';
    }
  }

  window.addEventListener('scroll', toggleStickyBtn, { passive: true });
  toggleStickyBtn();

  var stickyAddBtn = document.getElementById('sticky-add-to-cart');
  if (stickyAddBtn) {
    stickyAddBtn.addEventListener('click', function() {
      var mainAddBtn = document.querySelector('.w-commerce-commerceaddtocartbutton');
      if (mainAddBtn) mainAddBtn.click();
      else if (addToCartSection) addToCartSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  var notifyBtn = document.getElementById('sticky-notify-me');
  if (notifyBtn) {
    notifyBtn.addEventListener('click', function() {
      var subject = encodeURIComponent('Notification produit: {{ product.title | escape }}');
      var body = encodeURIComponent('Bonjour, je souhaite etre prevenu(e) quand ce produit sera de nouveau disponible : {{ product.title | escape }} ({{ product.url }})');
      window.location.href = 'mailto:{{ shop.email }}?subject=' + subject + '&body=' + body;
    });
  }
});
</script>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  var fullscreenGallery = document.querySelector('.fullscreen-gallery');
  var closeGalleryBtn = document.querySelector('.close-gallery');
  var featuredImage = document.querySelector('.featured-product-image');
  var thumbItems = document.querySelectorAll('.thumb-item');

  function openGallery() {
    if (!fullscreenGallery) return;
    fullscreenGallery.style.display = 'block';
    fullscreenGallery.offsetHeight;
    fullscreenGallery.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeGallery() {
    if (!fullscreenGallery) return;
    fullscreenGallery.classList.remove('active');
    setTimeout(function() {
      fullscreenGallery.style.display = 'none';
      document.body.style.overflow = '';
    }, 300);
  }

  if (featuredImage) {
    featuredImage.addEventListener('click', function() { openGallery(); });
  }

  /* Thumbnail click → swap featured image */
  thumbItems.forEach(function(thumb, idx) {
    thumb.addEventListener('click', function() {
      thumbItems.forEach(function(t) { t.classList.remove('active'); });
      thumb.classList.add('active');
      /* Swap featured image src */
      var thumbImg = thumb.querySelector('img');
      var featuredImg = featuredImage ? featuredImage.querySelector('img') : null;
      if (thumbImg && featuredImg) {
        var largeSrc = thumbImg.src.replace(/(_\d+x\d+|_\d+x)/, '_800x');
        featuredImg.src = largeSrc;
      }
    });
  });

  if (closeGalleryBtn) closeGalleryBtn.addEventListener('click', closeGallery);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeGallery(); });
  if (fullscreenGallery) {
    fullscreenGallery.addEventListener('click', function(e) { if (e.target === fullscreenGallery) closeGallery(); });
    var galleryContent = fullscreenGallery.querySelector('.fullscreen-gallery-content');
    if (galleryContent) galleryContent.addEventListener('click', function(e) { e.stopPropagation(); });
  }
});
</script>

{% schema %}
{
  "name": "Product Section",
  "presets": [
    {
      "name": "Product Section",
      "blocks": [
        { "type": "product_header" },
        { "type": "product_price" },
        { "type": "product_description" },
        { "type": "product_variations" },
        { "type": "product_accordion" }
      ]
    }
  ],
  "disabled_on": {
    "templates": ["404","article","blog","cart","collection","list-collections","customers/account",
      "customers/activate_account","customers/addresses","customers/login","customers/order",
      "customers/register","customers/reset_password","gift_card","index","page","password","search"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Sticky Button"
    },
    {
      "type": "checkbox",
      "id": "show_sticky_button",
      "label": "Show Sticky Button",
      "default": true
    },
    {
      "type": "text",
      "id": "sticky_btn_text_available",
      "label": "Button Text (Available)",
      "default": "Commander"
    },
    {
      "type": "text",
      "id": "sticky_btn_text_unavailable",
      "label": "Button Text (Sold Out)",
      "default": "Me prevenir"
    }
  ],
  "blocks": [
    {
      "name": "On Sale Label",
      "type": "on_sale_label",
      "settings": []
    },
    {
      "name": "Header",
      "type": "product_header",
      "settings": []
    },
    {
      "name": "Price",
      "type": "product_price",
      "settings": [
        {
          "type": "radio",
          "id": "currency_format",
          "label": "Currency Format",
          "options": [
            { "value": "with_currency", "label": "With Currency" },
            { "value": "without_currency", "label": "Without Currency" }
          ],
          "default": "without_currency"
        }
      ]
    },
    {
      "name": "Gallery",
      "type": "product_gallery",
      "settings": []
    },
    {
      "name": "Variations/Buttons",
      "type": "product_variations",
      "settings": []
    },
    {
      "name": "Description",
      "type": "product_description",
      "settings": []
    },
    {
      "name": "Product Accordion",
      "type": "product_accordion",
      "settings": [
        {
          "type": "text",
          "id": "accordion_title",
          "label": "Dropdown Title",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "accordion_description",
          "label": "Dropdown Description",
          "default": "<p>Details here</p>"
        },
        {
          "type": "page",
          "id": "accordion_page",
          "label": "Dropdown Page"
        }
      ]
    }
  ]
}
{% endschema %}
