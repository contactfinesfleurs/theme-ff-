{% liquid
  assign nav_active = ''
  if template.suffix == 'about'
    assign nav_active = 'us'
  elsif template.suffix == 'contact'
    assign nav_active = 'contact'
  endif
%}

<section class="ff-site">
  <div class="ff-wrap ff-wrap--page">
    {% render 'ff-min-nav', active: nav_active, class: 'ff-header--page' %}

    <div class="ff-content-box">
      <div class="ff-about-inner">
        <h1 class="ff-about-heading">FINES FLEURS</h1>

        {% if template.suffix == 'about' %}
          <p class="ff-about-sub">about us</p>
        {% elsif page.title != blank %}
          <p class="ff-about-sub">{{ page.title }}</p>
        {% endif %}

        <div class="ff-about-text">
          {% if page.content != blank %}
            {{ page.content }}
          {% else %}
            <p>{{ section.settings.fallback_text }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FF Minimal Page",
  "settings": [
    {
      "type": "textarea",
      "id": "fallback_text",
      "label": "Fallback text",
      "default": "Use this page to introduce your brand story, delivery terms or refund policy."
    }
  ],
  "presets": [
    {
      "name": "FF Minimal Page"
    }
  ]
}
{% endschema %}
